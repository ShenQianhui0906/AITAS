# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# Node / frontend
node_modules/
vendor/

# IDE
.idea/

# Runtime data — everything under storage/ is local data not synced to Git
storage/db/*
storage/uploads/*
storage/processed/*
storage/previews/*
storage/vectorstores/*
storage/tmp/*

# Keep directory structure in Git
!storage/db/.gitkeep
!storage/uploads/.gitkeep
!storage/uploads/coursewares/.gitkeep
!storage/processed/.gitkeep
!storage/processed/coursewares/.gitkeep
!storage/previews/.gitkeep
!storage/previews/coursewares/.gitkeep
!storage/vectorstores/.gitkeep
!storage/vectorstores/chroma/.gitkeep
!storage/tmp/.gitkeep

# Legacy data directories (migrated to storage/)
data/
uploads/
data.db

# 环境变量（包含密钥）
ENV
.env

# macOS
.DS_Store

# 临时文件
*.tmp
*.qlpreview/
*.native-preview.pdf
